#include <Servo.h>  //Need for Servo pulse output
#include <Adafruit_BNO08x.h>  //Need for Gyroscope
#include <SoftwareSerial.h>
#include <math.h>
#include <Wire.h>

//Gyroscope initialisation
Adafruit_BNO08x bno08x(-1);

sh2_SensorValue_t sensorValue;

//Default motor control pins
const byte left_front = 50;
const byte left_rear = 51;
const byte right_rear = 46;
const byte right_front = 47;

// For Ultrasonic sensor
const int trigPin = 48;
const int echoPin = 49;
float distance_cm;
long duration;

float wall_heading = 0.0;     // real heading where shortest sonar distance was found
float best_heading = 0.0;

// Declare robot width (cm)
float robot_width = 25;

// For Homing
float effort;
float heading;

// Serial Data input pin
#define BLUETOOTH_RX 19
// Serial Data output pin
#define BLUETOOTH_TX 18

SoftwareSerial BluetoothSerial(BLUETOOTH_RX, BLUETOOTH_TX);

Servo left_front_motor;   // create servo object to control Vex Motor Controller 29
Servo left_rear_motor;   // create servo object to control Vex Motor Controller 29
Servo right_rear_motor;  // create servo object to control Vex Motor Controller 29
Servo right_front_motor;  // create servo object to control Vex Motor Controller 29
Servo turret_motor;

//Serial Pointer
HardwareSerial *SerialCom;

int FRONT_SHORT_IR_SENSOR = A15; //sensor is attached on pinA14
int FRONT_LONG_IR_SENSOR = A12; //sensor is attached on pinA13
int REAR_SHORT_IR_SENSOR = A14; //sensor is attached on pinA15
int REAR_LONG_IR_SENSOR = A13; //sensor is attached on pinA12

byte serialRead = 0; //for control serial communication
int signalADCshort = 0; // the read out signal in 0-1023 corresponding to 0-5v
int signalADClong = 0; // the read out signal in 0-1023 corresponding to 0-5v

float distance_short;
float distance_long;

float distance_reading = 0;

float prev_distance = 0;
float current_distance;
float dt =0;
unsigned long prev_time = 0;
float vx, distance_y, vy;
float prev_y = 0;
float theta1, theta2, theta3, theta4;
float Rw = 0.025;
float L = 0.15;
float l = 0.09;
float distance_from_wall = 15;
float w_error_integral = 0.0;
float x_error_integral = 0.0;
float y_error_integral = 0.0;
float w_error_prev = 0.0;
float x_error_prev = 0.0;
float y_error_prev = 0.0;

float w_error_derivative = 0.0;
float x_error_derivative = 0.0;
float y_error_derivative = 0.0;
unsigned long prev_control_time = 0;
float heading_offset = 0.0;
float filtered_heading = 0.0;
bool heading_filter_initialized = false;

bool MAP_ORIENTATION;
bool final_lap_detected = false;

#define MAP_LENGTH 190
#define MAP_WIDTH 110
#define ROBOT_WIDTH 20
#define ROBOT_LENGTH 25

float cross_map_dimension = MAP_ORIENTATION ? MAP_WIDTH : MAP_LENGTH;

#define LANE_SPACING 10
#define MAP_EDGE_MARGIN 5

enum State {
    HOMING,
    FORWARD,
    RIGHT,
    BACKWARD,
    LEFT,
    STOP
  };

State state;
State prevState;

void setup(void) {
  state = HOMING;
  prevState = HOMING;

  pinMode(trigPin, OUTPUT);
  pinMode(echoPin, INPUT);
  digitalWrite(trigPin, LOW);

  turret_motor.attach(11);
  pinMode(LED_BUILTIN, OUTPUT);

  // Setup Gyro
  if (!bno08x.begin_I2C()) {
    Serial.println("BNO08x not detected");
    while (1);
  }

  // Enable rotation vector reporting AFTER successful initialization
  bno08x.enableReport(SH2_ROTATION_VECTOR);

  // Setup the Serial port and pointer, the pointer allows switching the debug info through the USB port(Serial) or Bluetooth port(Serial1) with ease.
  Serial.begin(115200);
  BluetoothSerial.begin(115200);
  enable_motors();
}

void loop() {
  _delay_ms(500);
  if (Serial.available()) { // Check for input from terminal
    
    serialRead = Serial.read(); // Read input

    if (serialRead == 49) { // Check for flag to execute, 49 is ascii for 1, stop serial printing
      Serial.end(); // end the serial communication to get the sensor data
    }
  }
  
  switch(state) {
    case HOMING:
      BluetoothSerial.println("HOMING");
      homing();
      prevState = HOMING;
      break;

  case FORWARD:
    BluetoothSerial.println("FORWARD");
    if (prevState == LEFT) {
      realignWithSideIR();        
    }
    if (prevState == HOMING) {
      homeDrive();
    } else {
      driveForwardStraight();
    }
 
    if (final_lap_detected) {
      BluetoothSerial.println("Final forward complete -> STOP");
      state = STOP;
    } else {
      if (prevState == HOMING) {
        state = LEFT;
      } else {
        state = RIGHT;
      }
    }

    prevState = FORWARD;
    delay(50);
    break;

    case RIGHT:
      BluetoothSerial.println("RIGHT");
      distance_from_wall += LANE_SPACING;
      moveRight();

      if (prevState == FORWARD) {
        state = BACKWARD;
      } else {
        state = FORWARD;
      }

      prevState = RIGHT;
      break;

    case BACKWARD:
      BluetoothSerial.println("BACK");
      if (prevState == LEFT) {
        realignWithSideIR();        
      }

      driveBackwardStraight();   // completes the backward move

      if (final_lap_detected) {
        BluetoothSerial.println("Final backward complete -> STOP");
        state = STOP;
      } else {
        if (prevState == HOMING) {
          state = LEFT;
        } else {
          state = RIGHT;
        }
      }

      prevState = BACKWARD; 
      break;
    
    case LEFT:
      BluetoothSerial.println("LEFT");
      moveLeft();
      realignWithSideIR();
      zeroHeading();     // reset corrected heading as new home
      wall_heading = 0.0;
      if (prevState == FORWARD) {
        state = BACKWARD;
      } else {
        state = FORWARD;
      }
      prevState = LEFT;
      break;

    case STOP:
      stop();
      disable_motors();
      prevState = STOP;
      break;
  }
}

void homeDrive() {

  float frontADClong = analogRead(FRONT_LONG_IR_SENSOR);
  float front_distance = 17948 * pow(frontADClong, -1.22);

  while (front_distance > 23) {

    frontADClong = analogRead(FRONT_LONG_IR_SENSOR);

    front_distance = 17948 * pow(frontADClong, -1.22);

    float motordif = 1.1;

    float left_front  = 200;
    float left_rear = 200;
    float right_front = motordif*200;
    float right_rear = motordif*200;

    // SIMPLE FORWARD DRIVE (no IK)
    Driveforward(left_front, left_rear, right_front, right_rear);
    delay(10);
  }
  stop();
}

void homing() {
  rotateThatBi();

  float frontsignalADClong = analogRead(FRONT_LONG_IR_SENSOR);
  float rearsignalADClong  = analogRead(REAR_LONG_IR_SENSOR);

  float front_distance_long = 17948 * pow(frontsignalADClong, -1.22);
  float rear_distance_long  = 17948 * pow(rearsignalADClong, -1.22);

  prevState = HOMING;

  if (front_distance_long <= rear_distance_long) {
    state = FORWARD;
  } else {
    state = BACKWARD;
  }
}

float median3(float a, float b, float c) {
  if (a > b) { float t = a; a = b; b = t; }
  if (b > c) { float t = b; b = c; c = t; }
  if (a > b) { float t = a; a = b; b = t; }
  return b;
}

float unwrapToReference(float angle, float reference) {
  while (angle - reference > 180.0) angle -= 360.0;
  while (angle - reference < -180.0) angle += 360.0;
  return angle;
}

float readIRcm(int pin) {
  float adc = analogRead(pin);
  float dist_cm;
  float frontADClong;
  float rearADClong;

  if (pin == FRONT_SHORT_IR_SENSOR) {
    dist_cm = 8.86 / (adc * (5.0 / 1024.0)) - 1.96;
  } else if (pin == REAR_SHORT_IR_SENSOR) {
    dist_cm = 8.19 / (adc * (5.0 / 1024.0)) - 1.48;
  } else if (pin == FRONT_LONG_IR_SENSOR) {
    dist_cm = 17948 * pow(adc, -1.22);
  } else {
    dist_cm = 17948 * pow(adc, -1.22);
  }

  if (dist_cm < 2.0) dist_cm = 2.0;
  if (dist_cm > 80.0) dist_cm = 80.0;

  return dist_cm;
}

void realignWithSideIR() {
  const float tolerance = 0.3;      
  const float turnSpeed = 75;       
  const unsigned long timeout_ms = 4000;

  unsigned long t0 = millis();

  while (millis() - t0 < timeout_ms) {
    float d_front = readIRMedian(FRONT_SHORT_IR_SENSOR);
    float d_rear  = readIRMedian(REAR_SHORT_IR_SENSOR);

    float diff = d_front - d_rear;

    if (abs(diff) <= tolerance) {
      stop();
      delay(250);

      zeroHeading();
      readOrientation();         // get current aligned heading
      wall_heading = heading;    // THIS is now the “correct” wall-parallel angle

      BluetoothSerial.print("IR aligned. New wall_heading = ");
      BluetoothSerial.println(wall_heading);
      return;
    }

    if (diff > 0) {
      rotateCCWRaw(turnSpeed);
    } else {
      rotateCWRaw(turnSpeed);
    }

    delay(40);
    stop();
    delay(30);
  }

  stop();
  BluetoothSerial.println("IR realignment timeout");
}

float wrap360(float angle) {
  while (angle >= 360.0) angle -= 360.0;
  while (angle < 0.0) angle += 360.0;
  return angle;
}

float angleDiff(float target, float current) {
  float diff = target - current;
  while (diff > 180.0) diff -= 360.0;
  while (diff < -180.0) diff += 360.0;
  return diff;
}

float absAngleStep(float new_heading, float old_heading) {
  float step = angleDiff(new_heading, old_heading);
  return abs(step);
}

void rotateStop() {
  stop();
}

void rotateToAngle(float wall_heading) {
  wall_heading = wrap360(wall_heading);

  readOrientation();
  float error = angleDiff(wall_heading, heading);

  while (abs(error) > 1.0) {
    readOrientation();
    error = angleDiff(wall_heading, heading);

    float turnSpeed = (float)(3.2 * abs(error));
    turnSpeed = constrain(turnSpeed, 60, 150);

    if (error > 0) {
      rotateCCWRaw(turnSpeed);
    } else {
      rotateCWRaw(turnSpeed);
    }
    delay(15);
  }

  stop();
  delay(120);
}

void moveRight() {

  float target_heading = heading;
  float Kp = 0;   // heading correction gain (tune this)
  float initial_distance = read_sonar();
  float distance = read_sonar();

  if (distance > 80) {
    final_lap_detected = true;
  }

  BluetoothSerial.println("GOING RIGHT");


  while (distance < initial_distance + 10) {
    
    distance = read_sonar();

    readOrientation();
    float error = angleDiff(best_heading, heading);

    // correction term
    float correction = Kp * error;
    correction = constrain(correction, -150, 150);

    float motordif = 1.1;

    float left_cmd  = 150 + correction;
    float right_cmd = motordif*(150 - correction);

    // SIMPLE FORWARD DRIVE (no IK)
    DriveRight(right_cmd, left_cmd);
    delay(10);
  }
  stop();
}

void moveLeft() {

  float Kp = 2.0;   // heading correction gain (tune this)
  float initial_distance = read_sonar();
  float distance = read_sonar();


  while (distance > 15) {
    
    distance = read_sonar();

    float motordif = 1.1;

    float left_cmd  = 200;
    float right_cmd = motordif*200;

    // SIMPLE FORWARD DRIVE (no IK)
    DriveLeft(right_cmd, left_cmd);
    delay(10);
  }
  stop();
}

void driveBackwardStraight() {
    float Kp_heading = 2;  // gyro heading correction gain
    float Kp_wall    = 2;  // wall distance correction gain
    float target_distance = distance_from_wall;

    // Initialize heading reference
    readOrientation();
    float target_heading = heading;

    float distance = readIRMedian(REAR_LONG_IR_SENSOR);  // use IR to detect end
    float wall_distance = read_sonar();                 // sonar for wall parallel

    while (distance > 20) {  // stop at end of lawn
        readOrientation();
        float heading_error = angleDiff(target_heading, heading);

        // Update distances
        distance = readIRMedian(REAR_LONG_IR_SENSOR);  // IR for end-of-path
        wall_distance = read_sonar();                 // sonar for wall distance
        float distance_error = target_distance - wall_distance;

        // Compute corrections
        float correction_heading = Kp_heading * heading_error;
        float correction_wall    = Kp_wall * distance_error;

        // Wheel commands for mecanum drive
        float left_front = 180 + correction_heading - correction_wall;
        float right_front = 180 - correction_heading + correction_wall;
        float left_rear   = 180 + correction_heading + correction_wall;
        float right_rear  = 180 - correction_heading - correction_wall;

        DriveBackward(left_front, left_rear, right_front, right_rear);

        delay(10);
    }

    stop();
    distance_from_wall += 10;  // prepare for next pass
}

void driveForwardStraight() {
    float Kp_heading = 2;  // gyro heading correction gain
    float Kp_wall    = 2;  // wall distance correction gain
    float target_distance = distance_from_wall;

    // Initialize heading reference
    readOrientation();
    float target_heading = heading;

    float distance = readIRMedian(FRONT_LONG_IR_SENSOR);  // IR for end-of-path
    float wall_distance = read_sonar();                 // sonar for wall distance

    while (distance > 20) {  // stop at end of lawn
        readOrientation();
        float heading_error = angleDiff(target_heading, heading);

        // Update distances
        distance = readIRMedian(FRONT_LONG_IR_SENSOR);  // IR for forward end
        wall_distance = read_sonar();                 // sonar for wall distance
        float distance_error = target_distance - wall_distance;

        // Compute corrections
        float correction_heading = Kp_heading * heading_error;
        float correction_wall    = Kp_wall * distance_error;

        // Wheel commands for mecanum drive
        float left_front  = 180 - correction_heading - correction_wall;
        float right_front = 180 + correction_heading + correction_wall;
        float left_rear   = 180 - correction_heading + correction_wall;
        float right_rear  = 180 + correction_heading - correction_wall;

        Driveforward(left_front, left_rear, right_front, right_rear);

        delay(10);
    }

    stop();
    distance_from_wall += 10;  // prepare for next pass
}

void rotateThatBi() {
  readOrientation();
  float prev_heading = heading;
  float swept_angle = 0.0;

  float min_distance = 9999.0;
  float best_heading = heading;

  const float scanSpeed = 110;
  const float min_update_margin = 0.5;

  while (swept_angle < 360.0) {
    float frontsignalADClong = analogRead(FRONT_LONG_IR_SENSOR);
    float rearsignalADClong = analogRead(REAR_LONG_IR_SENSOR);

    float front_distance_long = 17948 * pow(frontsignalADClong, -1.22);
    float rear_distance_long = 17948 * pow(rearsignalADClong, -1.22);
    rotateCCWRaw(scanSpeed);
    delay(10);

    readOrientation();

    float sonar_distance = 0.0;
    int valid_reads = 0;

    for (int i = 0; i < 3; i++) {
      float d = read_sonar();
      if (d > 0) {
        sonar_distance += d;
        valid_reads++;
      }
      delay(5);
    }

    if (valid_reads > 0) {
      sonar_distance /= valid_reads;
    } else {
      sonar_distance = 9999.0;
    }

    float step = absAngleStep(heading, prev_heading);
    swept_angle += step;
    prev_heading = heading;
    if (sonar_distance < (min_distance - min_update_margin)) {
      if (front_distance_long + rear_distance_long + ROBOT_LENGTH > 170) {
        min_distance = sonar_distance;
        best_heading = heading;
      }
    }
  }

  stop();
  delay(200);

  rotateToAngle(best_heading);
  wall_heading = best_heading;
}

void readOrientationRaw() {
  if (bno08x.getSensorEvent(&sensorValue)) {

    if (sensorValue.sensorId == SH2_ROTATION_VECTOR) {

      float qw = sensorValue.un.rotationVector.real;
      float qx = sensorValue.un.rotationVector.i;
      float qy = sensorValue.un.rotationVector.j;
      float qz = sensorValue.un.rotationVector.k;

      float yaw = atan2(2.0 * (qx*qy + qw*qz),
                        qw*qw + qx*qx - qy*qy - qz*qz);

      heading = yaw * 180.0 / PI;

      if (heading < 0)
        heading += 360.0;
    }
  }
}

void readOrientation() {
  float s1, s2, s3;

  delay(2);
  readOrientationRaw();
  s1 = wrap360(heading - heading_offset);
  delay(2);

  readOrientationRaw();
  s2 = wrap360(heading - heading_offset);
  delay(2);

  readOrientationRaw();
  s3 = wrap360(heading - heading_offset);

  if (!heading_filter_initialized) {
    heading = median3(s1, s2, s3);
  } else {
    s1 = unwrapToReference(s1, filtered_heading);
    s2 = unwrapToReference(s2, filtered_heading);
    s3 = unwrapToReference(s3, filtered_heading);

    heading = wrap360(median3(s1, s2, s3));
  }

  filtered_heading = heading;
  heading_filter_initialized = true;
}

void Driveforward(float left_front, float left_rear, float right_front, float right_rear) {
  left_front_motor.writeMicroseconds(1500 + left_front);
  left_rear_motor.writeMicroseconds(1500 + left_rear);
  right_rear_motor.writeMicroseconds(1500 - right_rear);
  right_front_motor.writeMicroseconds(1500 - right_front);
}

void DriveBackward(float left_front, float left_rear, float right_front, float right_rear) {
  left_front_motor.writeMicroseconds(1500 - left_front);
  left_rear_motor.writeMicroseconds(1500 - left_rear);
  right_rear_motor.writeMicroseconds(1500 + right_rear);
  right_front_motor.writeMicroseconds(1500 + right_front);
}

void DriveLeft(float right_cmd, float left_cmd) {
  left_front_motor.writeMicroseconds(1500 - left_cmd);
  left_rear_motor.writeMicroseconds(1500 + left_cmd);
  right_rear_motor.writeMicroseconds(1500 + right_cmd);
  right_front_motor.writeMicroseconds(1500 - right_cmd);
}

void DriveRight(float right_cmd, float left_cmd) {
  left_front_motor.writeMicroseconds(1500 + left_cmd);
  left_rear_motor.writeMicroseconds(1500 - left_cmd);
  right_rear_motor.writeMicroseconds(1500 - right_cmd);
  right_front_motor.writeMicroseconds(1500 + right_cmd);
}

void disable_motors() {
  left_front_motor.detach();   // detach the servo on pin left_front to turn Vex Motor Controller 29 Off
  left_rear_motor.detach();   // detach the servo on pin left_rear to turn Vex Motor Controller 29 Off
  right_rear_motor.detach();  // detach the servo on pin right_rear to turn Vex Motor Controller 29 Off
  right_front_motor.detach();  // detach the servo on pin right_front to turn Vex Motor Controller 29 Off

  pinMode(left_front, INPUT);
  pinMode(left_rear, INPUT);
  pinMode(right_rear, INPUT);
  pinMode(right_front, INPUT);
}

void enable_motors() {
  left_front_motor.attach(left_front);    // attaches the servo on pin left_front to turn Vex Motor Controller 29 On
  left_rear_motor.attach(left_rear);     // attaches the servo on pin left_rear to turn Vex Motor Controller 29 On
  right_rear_motor.attach(right_rear);   // attaches the servo on pin right_rear to turn Vex Motor Controller 29 On
  right_front_motor.attach(right_front);  // attaches the servo on pin right_front to turn Vex Motor Controller 29 On
}

void stop() {
  left_front_motor.writeMicroseconds(1500);
  left_rear_motor.writeMicroseconds(1500);
  right_rear_motor.writeMicroseconds(1500);
  right_front_motor.writeMicroseconds(1500);
}

float read_sonar() {
  // Clear trigger
  digitalWrite(trigPin, LOW);
  delayMicroseconds(2);

  // Send 10µs pulse
  digitalWrite(trigPin, HIGH);
  delayMicroseconds(10);
  digitalWrite(trigPin, LOW);

  // Read echo time

  duration = pulseIn(echoPin, HIGH);

  // Convert time to distance
  distance_cm = duration * 0.0343 / 2.0;

  return distance_cm;
}

void drive(float t1, float t2, float t3, float t4) {
  left_front_motor.writeMicroseconds(1500 + t1);
  right_front_motor.writeMicroseconds(1500 - t2);
  right_rear_motor.writeMicroseconds(1500 - t3);
  left_rear_motor.writeMicroseconds(1500 + t4);
}

float read_sonar_median() { 
  const int N = 7;   // must be odd
  float readings[N];

  // Collect readings
  for (int i = 0; i < N; i++) {
    readings[i] = read_sonar();
    delay(3);  // small gap between readings
  }

  // Simple bubble sort (small N so fine)
  for (int i = 0; i < N - 1; i++) {
    for (int j = i + 1; j < N; j++) {
      if (readings[j] < readings[i]) {
        float temp = readings[i];
        readings[i] = readings[j];
        readings[j] = temp;
      }
    }
  }

  // Return median
  return readings[N / 2];
}

float readIRMedian(int pin) {
  const int N = 5;
  float vals[N];

  for (int i = 0; i < N; i++) {
    vals[i] = readIRcm(pin);
    delay(4);
  }

  for (int i = 0; i < N - 1; i++) {
    for (int j = i + 1; j < N; j++) {
      if (vals[j] < vals[i]) {
        float tmp = vals[i];
        vals[i] = vals[j];
        vals[j] = tmp;
      }
    }
  }

  return vals[N / 2];
}

void zeroHeading() {
  readOrientationRaw();
  heading_offset = heading;
  filtered_heading = 0.0;
  heading_filter_initialized = false;
}

#define kp_rotation 1.4
void rotateCCWRaw(float speed_cmd) {
  // tune sign if robot turns wrong way
  left_front_motor.writeMicroseconds(1500 - kp_rotation * speed_cmd);
  left_rear_motor.writeMicroseconds(1500 - kp_rotation * speed_cmd);
  right_rear_motor.writeMicroseconds(1500 - kp_rotation * speed_cmd);
  right_front_motor.writeMicroseconds(1500 - kp_rotation * speed_cmd);
}

void rotateCWRaw(float speed_cmd) {
  // tune sign if robot turns wrong way
  left_front_motor.writeMicroseconds(1500 + kp_rotation * speed_cmd);
  left_rear_motor.writeMicroseconds(1500 + kp_rotation * speed_cmd);
  right_rear_motor.writeMicroseconds(1500 + kp_rotation * speed_cmd);
  right_front_motor.writeMicroseconds(1500 + kp_rotation * speed_cmd);
}
