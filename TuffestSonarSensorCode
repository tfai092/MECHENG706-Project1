#include <Servo.h>  //Need for Servo pulse output
#include <SoftwareSerial.h>

#include <Adafruit_BNO08x.h>  //Need for Gyroscope

//Gyroscope initialisation
Adafruit_BNO08x bno08x(-1);
sh2_SensorValue_t sensorValue;
float rad = 0.0;

// #define NO_READ_GYRO  //Uncomment if GYRO is not attached.

#define NO_HC -SR04  //Uncomment if HC-SR04 ultrasonic ranging sensor is not attached.

const int trigPin = 48;
const int echoPin = 49;

long duration;
float distance_cm;

// Serial Data input pin
#define BLUETOOTH_RX 19
// Serial Data output pin
#define BLUETOOTH_TX 18

SoftwareSerial BluetoothSerial(BLUETOOTH_RX, BLUETOOTH_TX);

int irsensor = A13; //sensor is attached on pinA0
byte serialRead = 0; //for control serial communication
int signalADC = 0; // the read out signal in 0-1023 corresponding to 0-5v
void setup() {
// put your setup code here, to run once:
Serial.begin(115200); // start serial communication

  pinMode(trigPin, OUTPUT);
  pinMode(echoPin, INPUT);
}
void loop() {
  // put your main code here, to run repeatedly:
// Clear trigger
  digitalWrite(trigPin, LOW);
  delayMicroseconds(2);

  // Send 10µs pulse
  digitalWrite(trigPin, HIGH);
  delayMicroseconds(10);
  digitalWrite(trigPin, LOW);

  // Read echo time
  duration = pulseIn(echoPin, HIGH);

  // Convert time to distance
  distance_cm = duration * 0.0343 / 2;

  Serial.print("Distance: ");
  Serial.print(distance_cm);
  Serial.println(" cm");

  delay(100);
}
