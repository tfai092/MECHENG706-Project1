#include <Servo.h>  //Need for Servo pulse output

float rad = 0.0;

//#define NO_HC -SR04  

//Default motor control pins
const byte left_front = 46;
const byte left_rear = 47;
const byte right_rear = 50;
const byte right_front = 51;

//Ultrasonic sensor pins
const int trigPin = 48;
const int echoPin = 49;

const unsigned int MAX_DIST = 23200;

//Servo objects
Servo left_font_motor;
Servo left_rear_motor;
Servo right_rear_motor;
Servo right_font_motor;
Servo turret_motor;

int speed_val = 100;

HardwareSerial *SerialCom;

//Filtering variables
#define MEDIAN_SIZE 5
float sonar_samples[MEDIAN_SIZE];

float filtered_distance = 0;
float alpha = 0.3;
float previous_valid_distance = 0;

float distance_cm = 0;
double duration;

void setup(void) {
  turret_motor.attach(11);
  pinMode(LED_BUILTIN, OUTPUT);

  pinMode(trigPin, OUTPUT);
  digitalWrite(trigPin, LOW);
  pinMode(echoPin, INPUT);

  SerialCom = &Serial;
  SerialCom->begin(115200);
  SerialCom->println("MECHENG706_Base_Code");
  delay(1000);
  SerialCom->println("Setup....");

  enable_motors();
  forward();

  delay(1000);
}

void loop() {

  if (Serial.available()) {
    byte serialRead = Serial.read();
    if (serialRead == 49) {
      Serial.end();
    }
  }

  distance_cm = get_filtered_distance();

  Serial.print("Distance: ");
  Serial.println(distance_cm);

  delay(50);
}

//---------------- FILTERED DISTANCE ----------------//

float get_filtered_distance() {
  float median = read_sonar_median();

  // Reject invalid readings
  if (median < 2 || median > 400) {
    return previous_valid_distance;
  }

  // Exponential smoothing
  filtered_distance = alpha * median + (1 - alpha) * filtered_distance;

  previous_valid_distance = filtered_distance;

  return filtered_distance;
}

//---------------- MEDIAN FILTER ----------------//

float read_sonar_median() {
  for (int i = 0; i < MEDIAN_SIZE; i++) {
    sonar_samples[i] = read_sonar();
    delay(5);
  }

  // Sort values
  for (int i = 0; i < MEDIAN_SIZE - 1; i++) {
    for (int j = i + 1; j < MEDIAN_SIZE; j++) {
      if (sonar_samples[j] < sonar_samples[i]) {
        float temp = sonar_samples[i];
        sonar_samples[i] = sonar_samples[j];
        sonar_samples[j] = temp;
      }
    }
  }

  return sonar_samples[MEDIAN_SIZE / 2];
}

//---------------- RAW SONAR ----------------//

float read_sonar() {
  digitalWrite(trigPin, LOW);
  delayMicroseconds(2);

  digitalWrite(trigPin, HIGH);
  delayMicroseconds(10);
  digitalWrite(trigPin, LOW);

  duration = pulseIn(echoPin, HIGH);

  float dist = duration * 0.0343 / 2;

  return dist;
}

//---------------- MOTOR CONTROL ----------------//

void disable_motors() {
  left_font_motor.detach();
  left_rear_motor.detach();
  right_rear_motor.detach();
  right_font_motor.detach();

  pinMode(left_front, INPUT);
  pinMode(left_rear, INPUT);
  pinMode(right_rear, INPUT);
  pinMode(right_front, INPUT);
}

void enable_motors() {
  left_font_motor.attach(left_front);
  left_rear_motor.attach(left_rear);
  right_rear_motor.attach(right_rear);
  right_font_motor.attach(right_front);
}

void stop() {
  left_font_motor.writeMicroseconds(1500);
  left_rear_motor.writeMicroseconds(1500);
  right_rear_motor.writeMicroseconds(1500);
  right_font_motor.writeMicroseconds(1500);
}

void forward() {
  left_font_motor.writeMicroseconds(1500 + speed_val);
  left_rear_motor.writeMicroseconds(1500 + speed_val);
  right_rear_motor.writeMicroseconds(1500 - speed_val);
  right_font_motor.writeMicroseconds(1500 - speed_val);
}

void reverse() {
  left_font_motor.writeMicroseconds(1500 - speed_val);
  left_rear_motor.writeMicroseconds(1500 - speed_val);
  right_rear_motor.writeMicroseconds(1500 + speed_val);
  right_font_motor.writeMicroseconds(1500 + speed_val);
}

void ccw() {
  left_font_motor.writeMicroseconds(1500 - speed_val);
  left_rear_motor.writeMicroseconds(1500 - speed_val);
  right_rear_motor.writeMicroseconds(1500 - speed_val);
  right_font_motor.writeMicroseconds(1500 - speed_val);
}

void cw() {
  left_font_motor.writeMicroseconds(1500 + speed_val);
  left_rear_motor.writeMicroseconds(1500 + speed_val);
  right_rear_motor.writeMicroseconds(1500 + speed_val);
  right_font_motor.writeMicroseconds(1500 + speed_val);
}

void strafe_left() {
  left_font_motor.writeMicroseconds(1500 - speed_val);
  left_rear_motor.writeMicroseconds(1500 + speed_val);
  right_rear_motor.writeMicroseconds(1500 + speed_val);
  right_font_motor.writeMicroseconds(1500 - speed_val);
}

void strafe_right() {
  left_font_motor.writeMicroseconds(1500 + speed_val);
  left_rear_motor.writeMicroseconds(1500 - speed_val);
  right_rear_motor.writeMicroseconds(1500 - speed_val);
  right_font_motor.writeMicroseconds(1500 + speed_val);
}
