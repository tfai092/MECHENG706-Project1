void setup(void) {

  state = HOMING;
  prevState = HOMING;

  BluetoothSerial.println("SETUP RAN");
  pinMode(trigPin, OUTPUT);
  pinMode(echoPin, INPUT);
  digitalWrite(trigPin, LOW);

  turret_motor.attach(11);
  pinMode(LED_BUILTIN, OUTPUT);

  // Setup Gyro
  if (!bno08x.begin_I2C()) {
    Serial.println("BNO08x not detected");
    while (1);
  }

  // Enable rotation vector reporting AFTER successful initialization
  bno08x.enableReport(SH2_ROTATION_VECTOR);

  // Setup the Serial port and pointer, the pointer allows switching the debug info through the USB port(Serial) or Bluetooth port(Serial1) with ease.
  Serial.begin(115200);
  BluetoothSerial.begin(115200);
  enable_motors();
}

void loop() {
  _delay_ms(500);
  // put your main code here, to run repeatedly:
  if (Serial.available()) { // Check for input from terminal
    
    serialRead = Serial.read(); // Read input

    if (serialRead == 49) { // Check for flag to execute, 49 is ascii for 1, stop serial printing
      Serial.end(); // end the serial communication to get the sensor data
    }
  }
  
  switch(state) {
    case HOMING:
      
      homing();
      prevState = HOMING;
      break;

    case FORWARD:
      InverseKinematics(); 

      if (prevState == HOMING) {
        state = LEFT;
      } else {
        state = RIGHT;
      }
      prevState = FORWARD;
      delay(50);
    break;

    case RIGHT:
    BluetoothSerial.println("NEXT STATE = RIGHT");

    if (prevState != RIGHT) {   // only runs once on entry
      distance_from_wall += 25;
    }

    InverseKinematics();

    if (prevState == FORWARD) {
      state = BACKWARD;
    } else {
      state = FORWARD;
    }

    prevState = RIGHT;
    break;

    case BACKWARD:
    BluetoothSerial.println("NEXT STATE = BACKWARD");

      InverseKinematics();
      if (prevState == HOMING) {
        state = LEFT;
      } else  {
        state = RIGHT;
      }
      prevState = BACKWARD;
      break;
    
    case LEFT:
    BluetoothSerial.println("NEXT STATE = LEFT");

      InverseKinematics();
      // BluetoothSerial.println("WE ARE AT HOME");
      
      if (prevState == FORWARD) {
        state = BACKWARD;
      } else {
        state = FORWARD;
      }
      prevState = LEFT;
      break;


    case STOP:
      stop();
      disable_motors();
      prevState = STOP;
      break;
  }
}


void homing() {
  //BluetoothSerial.println("=== HOMING TEST START ===");
  delay(500);

  stop();
  delay(300);

  rotateThatBi();

  float frontsignalADClong = analogRead(FRONT_LONG_IR_SENSOR);
  float rearsignalADClong  = analogRead(REAR_LONG_IR_SENSOR);

  float front_distance_long = 17948 * pow(frontsignalADClong, -1.22);
  float rear_distance_long  = 17948 * pow(rearsignalADClong, -1.22);

  prevState = HOMING;

  if (front_distance_long <= rear_distance_long) {
    state = FORWARD;
    BluetoothSerial.println("NEXT STATE = FORWARD");
  } else {
    state = BACKWARD;
    BluetoothSerial.println("NEXT STATE = BACKWARD");
  }
}

void InverseKinematics() {

  float target_heading = wall_heading;
  float w_error, x_error, y_error, overall_error;

  distance_y = read_sonar();

  if (state == BACKWARD) {
    signalADCshort = analogRead(REAR_SHORT_IR_SENSOR);
    signalADClong  = analogRead(REAR_LONG_IR_SENSOR);
  } else {
    signalADCshort = analogRead(FRONT_SHORT_IR_SENSOR);
    signalADClong  = analogRead(FRONT_LONG_IR_SENSOR);
  }

  // Convert IR readings to distance
  distance_long  = 17948 * pow(signalADClong, -1.22);
  distance_short = 12.10 / (signalADCshort * (5.0 / 1024.0)) - 0.42;

  if (distance_long >= 25) {
    current_distance = distance_long;
  } 
  else {
    current_distance = distance_short;
  }

  readOrientation();
  x_error = current_distance;
  y_error = distance_y - distance_from_wall;
  w_error = angleDiff(target_heading, heading);

  if (state == FORWARD) {
    overall_error = x_error;
  } else if (state == RIGHT) {
    overall_error = y_error;
  } else if (state == LEFT) {
    overall_error = y_error;
  } else if (state == BACKWARD) {
    overall_error = x_error;
  } else if (state == HOMING) {
    overall_error = w_error;
  }

  // Reset integral when entering the function
  w_error_integral = 0.0;
  prev_control_time = millis();

  while (abs(overall_error) > 5) {

    unsigned long now = millis();
    if (now - prev_time >= 30) {  
      prev_time = now;

      // time step for integral
      float dt_sec = (now - prev_control_time) / 1000.0;
      prev_control_time = now;

      readOrientation();
      distance_y = read_sonar();

      if (state == FORWARD) {
        signalADCshort = analogRead(FRONT_SHORT_IR_SENSOR);
        signalADClong  = analogRead(FRONT_LONG_IR_SENSOR);
      } else if (state == BACKWARD) {
        signalADCshort = analogRead(REAR_SHORT_IR_SENSOR);
        signalADClong  = analogRead(REAR_LONG_IR_SENSOR);
      }

      // Convert IR readings to distance
      distance_long  = 17948 * pow(signalADClong, -1.22);
      distance_short = 12.10 / (signalADCshort * (5.0 / 1024.0)) - 0.42;

      if (distance_long >= 25) {
        current_distance = distance_long;
      } else {
        current_distance = distance_short;
      }

      x_error = current_distance - 10;
      y_error = distance_y - distance_from_wall;
      w_error = angleDiff(target_heading, heading);


      // BluetoothSerial.print("    heading=   ");
      // BluetoothSerial.println(heading);

      float kp_x, kp_y, Kp, Ki;
      float omega;

      if (state == FORWARD || state == BACKWARD) {
        kp_x = 0.25;
        kp_y = 0.05;
        Kp = 0.03;
        Ki = 0.0005;   // start small
      } else if (state == RIGHT || state == LEFT) {
        kp_x = 0.0;
        kp_y = 0.3;
        Kp = 0.05;   // optional small heading correction while strafing
        Ki = 0;  // start very small
      } else {
        kp_x = 0;
        kp_y = 0;
        Kp = 0.1;
        Ki = 0;
      }

      // Integral on heading error
      if (abs(w_error) < 20.0) {
        w_error_integral += w_error * dt_sec;
      }

      // anti-windup clamp
      w_error_integral = constrain(w_error_integral, -5.0, 5.0);
      // BluetoothSerial.print("w_error_integral=   ");
      // BluetoothSerial.println(w_error_integral);

      vy = -kp_y * y_error;
      vx = kp_x * x_error;
      omega = Kp * w_error + Ki * w_error_integral;

      if (vx > 0) {
        vx = constrain(vx, 1, 10);
      } else if (vx < 0) {
        vx = constrain(vx, -10, -1);
      }

      if (vy > 0) {
        vy = constrain(vy, 1, 10);
      } else if (vy < 0) {
        vy = constrain(vy, -10, -1);
      }
      // BluetoothSerial.print("vy   ");
      // BluetoothSerial.println(vy);

      theta1 = (1.0 / Rw) * (vx - vy - (L + l) * omega);   // front left
      theta2 = (-1.0 / Rw) * (vx + vy + (L + l) * omega);  // front right
      theta3 = (-1.0 / Rw) * (vx - vy + (L + l) * omega);  // back left
      theta4 = (1.0 / Rw) * (vx + vy - (L + l) * omega);   // back right

      if (state == FORWARD) {
        forward(theta1, theta2, theta3, theta4);
        overall_error = x_error;
      } else if (state == RIGHT) {
        strafe_right(theta1, theta2, theta3, theta4);
        overall_error = y_error;
      } else if (state == LEFT) {
        strafe_left(theta1, theta2, theta3, theta4);
        overall_error = y_error;
      } else if (state == HOMING) {
        ccw(theta1, theta2, theta3, theta4);
        overall_error = w_error;
      } else if (state == BACKWARD) {
        reverse(theta1, theta2, theta3, theta4);
        overall_error = x_error;
      }
    }
  }
}


float wrap360(float angle) {
  while (angle >= 360.0) angle -= 360.0;
  while (angle < 0.0) angle += 360.0;
  return angle;
}

float angleDiff(float target, float current) {
  float diff = target - current;
  while (diff > 180.0) diff -= 360.0;
  while (diff < -180.0) diff += 360.0;
  return diff;
}

float absAngleStep(float new_heading, float old_heading) {
  float step = angleDiff(new_heading, old_heading);
  return abs(step);
}

void rotateStop() {
  stop();
}

void rotateToAngle(float target_heading) {
  target_heading = wrap360(target_heading);

  readOrientation();
  float error = angleDiff(target_heading, heading);

  while (abs(error) > 1.0) {
    readOrientation();
    error = angleDiff(target_heading, heading);

    int turnSpeed = (int)(3.5 * abs(error));
    turnSpeed = constrain(turnSpeed, 45, 140);

    BluetoothSerial.print("Rotate target: ");
    BluetoothSerial.print(target_heading);
    BluetoothSerial.print("  heading: ");
    BluetoothSerial.print(heading);
    // BluetoothSerial.print("  error: ");
    // BluetoothSerial.println(error);

    if (error > 0) {
      rotateCCWRaw(turnSpeed);
    } else {
      rotateCWRaw(turnSpeed);
    }

    delay(15);
  }

  stop();
  delay(120);

  // Fine correction pass in case of overshoot/coast
  readOrientation();
  error = angleDiff(target_heading, heading);

  while (abs(error) > 1) {
    readOrientation();
    error = angleDiff(target_heading, heading);

    int turnSpeed = 30;   // gentle trim speed

    if (error > 0) {
      rotateCCWRaw(turnSpeed);
    } else {
      rotateCWRaw(turnSpeed);
    }

    delay(10);
    stop();
    delay(25);
  }

  stop();
}

void rotateThatBi() {
  readOrientation();
  float prev_heading = heading;
  float swept_angle = 0.0;

  float min_distance = 9999.0;
  float best_heading = heading;

  const int scanSpeed = 70;     // constant speed for whole scan
  const float min_update_margin = 0.3;   // only accept a new min if clearly lower

  while (swept_angle < 360.0) {
    rotateCCWRaw(scanSpeed);
    delay(20);

    readOrientation();

    float sonar_distance = 0.0;
    int valid_reads = 0;

    for (int i = 0; i < 3; i++) {
      float d = read_sonar();
      if (d > 0) {
        sonar_distance += d;
        valid_reads++;
      }
      delay(5);
    }

    if (valid_reads > 0) {
      sonar_distance /= valid_reads;
    } else {
      sonar_distance = 9999.0;
    }

    float step = absAngleStep(heading, prev_heading);
    swept_angle += step;
    prev_heading = heading;

    //BluetoothSerial.print("Heading: ");
    //BluetoothSerial.print(heading);
    BluetoothSerial.print("  Sonar: ");
    BluetoothSerial.println(sonar_distance);
    //BluetoothSerial.print("  Swept: ");
    //BluetoothSerial.println(swept_angle);

    // update only if genuinely lower
    if (sonar_distance < (min_distance - min_update_margin)) {
      min_distance = sonar_distance;
      best_heading = heading;

      BluetoothSerial.print("NEW MIN -> dist: ");
      BluetoothSerial.print(min_distance);
      BluetoothSerial.print(" heading: ");
      BluetoothSerial.println(best_heading);
    }
  }

  stop();
  delay(200);

  rotateToAngle(best_heading);
  wall_heading = best_heading;

  //BluetoothSerial.print("FINAL WALL HEADING: ");
  //BluetoothSerial.println(wall_heading);
}

void readOrientation() {
  if (bno08x.getSensorEvent(&sensorValue)) {

    if (sensorValue.sensorId == SH2_ROTATION_VECTOR) {

      float qw = sensorValue.un.rotationVector.real;
      float qx = sensorValue.un.rotationVector.i;
      float qy = sensorValue.un.rotationVector.j;
      float qz = sensorValue.un.rotationVector.k;

      // Convert quaternion to yaw (heading)
      float yaw = atan2(2.0*(qx*qy + qw*qz),
                        qw*qw + qx*qx - qy*qy - qz*qz);

      heading = yaw * 180.0 / PI;

      if (heading < 0)
        heading += 360;

      //BluetoothSerial.print("Compass Heading: ");
      //BluetoothSerial.print(heading);
      //BluetoothSerial.println(" degrees");
    }
  }
}

void disable_motors() {
  left_front_motor.detach();   // detach the servo on pin left_front to turn Vex Motor Controller 29 Off
  left_rear_motor.detach();   // detach the servo on pin left_rear to turn Vex Motor Controller 29 Off
  right_rear_motor.detach();  // detach the servo on pin right_rear to turn Vex Motor Controller 29 Off
  right_front_motor.detach();  // detach the servo on pin right_front to turn Vex Motor Controller 29 Off

  pinMode(left_front, INPUT);
  pinMode(left_rear, INPUT);
  pinMode(right_rear, INPUT);
  pinMode(right_front, INPUT);
}

void enable_motors() {
  left_front_motor.attach(left_front);    // attaches the servo on pin left_front to turn Vex Motor Controller 29 On
  left_rear_motor.attach(left_rear);     // attaches the servo on pin left_rear to turn Vex Motor Controller 29 On
  right_rear_motor.attach(right_rear);   // attaches the servo on pin right_rear to turn Vex Motor Controller 29 On
  right_front_motor.attach(right_front);  // attaches the servo on pin right_front to turn Vex Motor Controller 29 On
}

void stop()
{
  left_front_motor.writeMicroseconds(1500);
  left_rear_motor.writeMicroseconds(1500);
  right_rear_motor.writeMicroseconds(1500);
  right_front_motor.writeMicroseconds(1500);
}

int read_sonar() {
  // Clear trigger
  digitalWrite(trigPin, LOW);
  delayMicroseconds(2);

  // Send 10µs pulse
  digitalWrite(trigPin, HIGH);
  delayMicroseconds(10);
  digitalWrite(trigPin, LOW);

  // Read echo time
  duration = pulseIn(echoPin, HIGH);

  // Convert time to distance
  distance_cm = duration * 0.0343 / 2;

  return distance_cm;
}


#define kppp 1
void forward(float a, float b, float c, float d) {
  left_front_motor.writeMicroseconds(1500 + kppp*a);
  left_rear_motor.writeMicroseconds(1500 + kppp*d);
  right_rear_motor.writeMicroseconds(1500 + kppp*c);
  right_front_motor.writeMicroseconds(1500 + kppp*b);
}

void reverse(float a, float b, float c, float d) {
  left_front_motor.writeMicroseconds(1500 - kppp*a);
  left_rear_motor.writeMicroseconds(1500 - kppp*d);
  right_rear_motor.writeMicroseconds(1500 - kppp*c);
  right_front_motor.writeMicroseconds(1500 - kppp*b);
}

void ccw(float a, float b, float c, float d) {
  left_front_motor.writeMicroseconds(1500 + kppp*a);
  left_rear_motor.writeMicroseconds(1500 + kppp*d);
  right_rear_motor.writeMicroseconds(1500 + kppp*c);
  right_front_motor.writeMicroseconds(1500 + kppp*b);
}

void cw(float speed_cw) {
  left_front_motor.writeMicroseconds(1500 + speed_cw);
  left_rear_motor.writeMicroseconds(1500 + speed_cw);
  right_rear_motor.writeMicroseconds(1500 + speed_cw);
  right_front_motor.writeMicroseconds(1500 + speed_cw);
}

void strafe_left(float a, float b, float c, float d) {
  left_front_motor.writeMicroseconds(1500 - kppp*a);   // forward
  left_rear_motor.writeMicroseconds(1500 + kppp*d);    // backward
  right_rear_motor.writeMicroseconds(1500 - kppp*c);   // forward (right side is reversed)
  right_front_motor.writeMicroseconds(1500 + kppp*b);
}

void strafe_right(float a, float b, float c, float d) {
  left_front_motor.writeMicroseconds(1500 + kppp*a);   // forward
  left_rear_motor.writeMicroseconds(1500 - kppp*d);    // backward
  right_rear_motor.writeMicroseconds(1500 + kppp*c);   // forward (right side is reversed)
  right_front_motor.writeMicroseconds(1500 - kppp*b);  // backward (right side is reversed)
}
#define kp_rotation 1.4
void rotateCCWRaw(int speed_cmd) {
  // tune sign if robot turns wrong way
  left_front_motor.writeMicroseconds(1500 - kp_rotation * speed_cmd);
  left_rear_motor.writeMicroseconds(1500 - kp_rotation * speed_cmd);
  right_rear_motor.writeMicroseconds(1500 - kp_rotation * speed_cmd);
  right_front_motor.writeMicroseconds(1500 - kp_rotation * speed_cmd);
}

void rotateCWRaw(int speed_cmd) {
  // tune sign if robot turns wrong way
  left_front_motor.writeMicroseconds(1500 + kp_rotation * speed_cmd);
  left_rear_motor.writeMicroseconds(1500 + kp_rotation * speed_cmd);
  right_rear_motor.writeMicroseconds(1500 + kp_rotation * speed_cmd);
  right_front_motor.writeMicroseconds(1500 + kp_rotation * speed_cmd);
}

