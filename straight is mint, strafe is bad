void InverseKinematics() {

  float target_heading = wall_heading;
  float w_error, x_error, y_error, overall_error;

  distance_y = read_sonar();

  if (state == BACKWARD) {
    signalADCshort = analogRead(REAR_SHORT_IR_SENSOR);
    signalADClong  = analogRead(REAR_LONG_IR_SENSOR);
  } else {
    signalADCshort = analogRead(FRONT_SHORT_IR_SENSOR);
    signalADClong  = analogRead(FRONT_LONG_IR_SENSOR);
  }

  // Convert IR readings to distance
  distance_long  = 17948 * pow(signalADClong, -1.22);
  distance_short = 12.10 / (signalADCshort * (5.0 / 1024.0)) - 0.42;

  //if (distance_long >= 25) {
    current_distance = distance_long;
  //} 
  //else {
   // current_distance = distance_short;
  //}

  readOrientation();
  x_error = current_distance;
  y_error = distance_y - distance_from_wall;
  w_error = angleDiff(target_heading, heading);

  if (state == FORWARD) {
    overall_error = x_error;
  } else if (state == RIGHT) {
    overall_error = y_error;
  } else if (state == LEFT) {
    overall_error = y_error;
  } else if (state == BACKWARD) {
    overall_error = x_error;
  } else if (state == HOMING) {
    overall_error = w_error;
  }

  // Reset integral when entering the function
  w_error_integral = 0.0;
  prev_control_time = millis();

  while (abs(overall_error) > 5) {

    unsigned long now = millis();
    if (now - prev_time >= 100) {  
      prev_time = now;

      // time step for integral
      float dt_sec = (now - prev_control_time) / 1000.0;
      prev_control_time = now;

      readOrientation();
      distance_y = get_filtered_distance();
      BluetoothSerial.println("Sonar Reading: ");
      BluetoothSerial.println(distance_y);

      if (state == FORWARD || prevState == FORWARD) {
        signalADCshort = analogRead(FRONT_SHORT_IR_SENSOR);
        signalADClong  = analogRead(FRONT_LONG_IR_SENSOR);
      } else if (state == BACKWARD || prevState == BACKWARD) {
        signalADCshort = analogRead(REAR_SHORT_IR_SENSOR);
        signalADClong  = analogRead(REAR_LONG_IR_SENSOR);
      }

      // Convert IR readings to distance
      distance_long  = 17948 * pow(signalADClong, -1.22);
      distance_short = 12.10 / (signalADCshort * (5.0 / 1024.0)) - 0.42;

      //if (distance_long >= 25) {
        current_distance = distance_long;
      //} else {
      //  current_distance = distance_short;
      //}

      x_error = current_distance - 10;
      y_error = distance_y - distance_from_wall;
      w_error = angleDiff(target_heading, heading);


      // BluetoothSerial.print("    heading=   ");
      // BluetoothSerial.println(heading);

      

      float kp_x, kp_y, Kp, Ki;
      float omega;

      if (prevState == HOMING) {
        kp_x = 0.25;
        kp_y = 0.0;
        Kp = 0.03;
        Ki = 0.00;   // start small
      } else if (state == FORWARD || state == BACKWARD) {
        kp_x = 0.25;
        kp_y = 0.25;
        Kp = 0.03;
        Ki = 0.001;   // start small
      } else if (state == RIGHT || state == LEFT) {
        kp_x = 0.25;
        kp_y = 0.25;
        Kp = 0.03;   // optional small heading correction while strafing
        Ki = 0;  // start very small
      } else {
        kp_x = 0;
        kp_y = 0;
        Kp = 0.1;
        Ki = 0;
      }

      // Integral on heading error
      if (abs(w_error) < 20.0) {
        w_error_integral += w_error * dt_sec;
      }

      // anti-windup clamp
      w_error_integral = constrain(w_error_integral, -5.0, 5.0);



      // BluetoothSerial.print("w_error_integral=   ");
      // BluetoothSerial.println(w_error_integral);

      vy = kp_y * y_error;
      vx = kp_x * x_error;
      omega = Kp * w_error + Ki * w_error_integral;

      if (vx > 0) {
        vx = constrain(vx, 0, 4);
      } else if (vx < 0) {
        vx = constrain(vx, -4, 0);
      }

      if (vy > 0) {
        vy = constrain(vy, 0, 7);
      } else if (vy < 0) {
        vy = constrain(vy, -7, 0);
      }
      // BluetoothSerial.print("vy   ");
      // BluetoothSerial.println(vy);
      vx=5;

      theta1 = (1.0 / Rw) * (vx - vy - (L + l) * omega);   // front left
      theta2 = (-1.0 / Rw) * (vx + vy + (L + l) * omega);  // front right
      theta3 = (-1.0 / Rw) * (vx - vy + (L + l) * omega);  // back left
      theta4 = (1.0 / Rw) * (vx + vy - (L + l) * omega);   // back right

      // BluetoothSerial.print("THETA1: ");
      // BluetoothSerial.print(theta1);
      // BluetoothSerial.print("  theta2: ");
      // BluetoothSerial.print(theta2);
      // BluetoothSerial.print("  theta3: ");
      // BluetoothSerial.print(theta3);
      // BluetoothSerial.print("  theta4: ");
      // BluetoothSerial.println(theta4);

      if (state == FORWARD) {
        forward(theta1, theta2, theta3, theta4);
        overall_error = x_error;
      } else if (state == RIGHT) {
        strafe_right(theta1, theta2, theta3, theta4);
        overall_error = y_error;
      } else if (state == LEFT) {
        strafe_left(theta1, theta2, theta3, theta4);
        overall_error = y_error;
      } else if (state == HOMING) {
        ccw(theta1, theta2, theta3, theta4);
        overall_error = w_error;
      } else if (state == BACKWARD) {
        reverse(theta1, theta2, theta3, theta4);
        overall_error = x_error;
      }
    }
  }
  delay(500);
}

void straighteningTest() {
  const float target_heading = 0.0;   // because robot is zeroed when lined up
  const float test_vx = 5.0;          // constant forward speed
  const float Kp = 0.6;              // start small
  const float Ki = 0.25;               // start with P only first
  const float kp_x = 0.35;
  const float kp_y = 0.1;

  w_error_integral = 0.0;
  prev_control_time = millis();

  while (true) {
    unsigned long now = millis();
    float dt_sec = (now - prev_control_time) / 1000.0;

    if (dt_sec < 0.02) continue;   // ~50 Hz loop
    prev_control_time = now;

    readOrientation();

    signalADCshort = analogRead(FRONT_SHORT_IR_SENSOR);
    signalADClong  = analogRead(FRONT_LONG_IR_SENSOR);

    distance_long  = 17948 * pow(signalADClong, -1.22);
    distance_short = 12.10 / (signalADCshort * (5.0 / 1024.0)) - 0.42;

    float current_distance = distance_long;
    float distance_y = read_sonar();

    float w_error = angleDiff(target_heading, heading);
    float x_error = current_distance - 5;
    float y_error = distance_y - 20;

    if (abs(w_error) < 20.0) {
      w_error_integral += w_error * dt_sec;
    }

    w_error_integral = constrain(w_error_integral, -10.0, 10.0);

    float omega = Kp * w_error + Ki * w_error_integral;
    float vx = kp_x * x_error;
    float vy = kp_y * y_error;

    vy = constrain(vy, -2.0, 2.0);
    vx = constrain(vx, 0, 5);

    theta1 = (1.0 / Rw) * (vx - vy - (L + l) * omega);   // front left
    theta2 = (-1.0 / Rw) * (vx + vy + (L + l) * omega);  // front right
    theta3 = (-1.0 / Rw) * (vx - vy + (L + l) * omega);  // back left
    theta4 = (1.0 / Rw) * (vx + vy - (L + l) * omega);   // back right

    forward(theta1, theta2, theta3, theta4);

    BluetoothSerial.print("heading: ");
    BluetoothSerial.print(heading);
    BluetoothSerial.print("  w_error: ");
    BluetoothSerial.print(w_error);
    BluetoothSerial.print("  omega: ");
    BluetoothSerial.println(omega);

    // stop test by sending 's' in Serial monitor
    if (Serial.available()) {
      char c = Serial.read();
      if (c == 's') {
        stop();
        break;
      }
    }
  }
}

