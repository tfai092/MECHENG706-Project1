void InverseKinematics() {
  
  float target_heading = 240;
  float w_error, x_error, y_error, overall_error;

  distance_y = read_sonar();

  signalADCshort = analogRead(FRONT_SHORT_IR_SENSOR);
  signalADClong  = analogRead(FRONT_LONG_IR_SENSOR);

  // Convert IR readings to distance
  distance_long  = 17948 * pow(signalADClong, -1.22);
  distance_short = 12.10 / (signalADCshort * (5.0 / 1024.0)) - 0.42;

  if (distance_long >= 25) {
    current_distance = distance_long;
  } 
  else {
    current_distance = distance_short;
  }

  x_error = current_distance;
  y_error = distance_y - distance_from_wall;

  if (state == FORWARD) {
    BluetoothSerial.println("FORWARD");
    overall_error = x_error;
  } else if (state == RIGHT) {
    BluetoothSerial.println("RIGHT");
    overall_error = y_error;
  } else if (state == BACKWARD) {
    BluetoothSerial.println("BACK");
    overall_error = x_error;
  }

  while (abs(overall_error) > 15) {
    //BluetoothSerial.println(overall_error);
    unsigned long now = millis();
    if (now - prev_time >= 100) {   // 50 Hz loop
      prev_time = now;
      readOrientation();
      distance_y = read_sonar();

      signalADCshort = analogRead(FRONT_SHORT_IR_SENSOR);
      signalADClong  = analogRead(FRONT_LONG_IR_SENSOR);

      // Convert IR readings to distance
      distance_long  = 17948 * pow(signalADClong, -1.22);
      distance_short = 12.10 / (signalADCshort * (5.0 / 1024.0)) - 0.42;

      if (distance_long >= 25) {
        current_distance = distance_long;
      } 
      else {
        current_distance = distance_short;
      }

      x_error = current_distance;
      y_error = distance_y - distance_from_wall;
      w_error = target_heading - heading;

      // Wrap angle
      if (w_error > 180) w_error -= 360;
      if (w_error < -180) w_error += 360;

      float kp_x = 0.1;
      float kp_y = 5;
      float Kp = 0.5;

      float omega  = Kp * w_error;
    
      if (state == FORWARD) {
        vx = kp_x * x_error;
        vy=0;
      } else if (state == RIGHT) {
        vy = kp_y * y_error;
        vx=0;
      }
      //
      // vy = constrain(vy, -20, 20);
      // vx = constrain(vx, -20, 20);

      theta1 = (1.0 / Rw) * (vx - vy - (L + l) * omega);  // front left
      theta2 = (1.0 / Rw) * (vx + vy + (L + l) * omega);  // front right
      theta3 = (1.0 / Rw) * (vx - vy + (L + l) * omega);  // back left
      theta4 = (1.0 / Rw) * (vx + vy - (L + l) * omega);  // back right 

      if (state == FORWARD) {
        forward(theta1, theta2, theta3, theta4);
        overall_error = x_error;
      } else if (state == RIGHT) {
        strafe_right(theta1, theta2, theta3, theta4);
        overall_error = y_error;
      } else if (state == BACKWARD) {
        reverse(theta1, theta2, theta3, theta4);
        overall_error = x_error;
      }
    }
}
BluetoothSerial.println("DONE LOOP");
}


void orientate() {
  readOrientation();
  float w_error = perpen - heading; // Desired angle(perpendicular to wall) - current compass angle

  while (abs(w_error) > 2) {
    BluetoothSerial.println(w_error);
    readOrientation();
    w_error = perpen - heading; // Desired angle(perpendicular to wall) - current compass angle
    effort = w_error * 1.2;  // Control effort

    if (w_error > 0) {
      // Serial.println("CW ");
      cw(effort);
    }
    else {
      // Serial.println("CCW ");
      ccw(effort);
    }
  }
}

void readOrientation() {
  if (bno08x.getSensorEvent(&sensorValue)) {

    if (sensorValue.sensorId == SH2_ROTATION_VECTOR) {

      float qw = sensorValue.un.rotationVector.real;
      float qx = sensorValue.un.rotationVector.i;
      float qy = sensorValue.un.rotationVector.j;
      float qz = sensorValue.un.rotationVector.k;

      // Convert quaternion to yaw (heading)
      float yaw = atan2(2.0*(qx*qy + qw*qz), qw*qw + qx*qx - qy*qy - qz*qz);

      heading = yaw * 180.0 / PI;

      if (heading < 0) {
        heading += 360;
      }

      //BluetoothSerial.print("Compass Heading: ");
      //BluetoothSerial.print(heading);
      //BluetoothSerial.println(" degrees");
    }
  }
}

void disable_motors() {
  left_front_motor.detach();   // detach the servo on pin left_front to turn Vex Motor Controller 29 Off
  left_rear_motor.detach();   // detach the servo on pin left_rear to turn Vex Motor Controller 29 Off
  right_rear_motor.detach();  // detach the servo on pin right_rear to turn Vex Motor Controller 29 Off
  right_front_motor.detach();  // detach the servo on pin right_front to turn Vex Motor Controller 29 Off

  pinMode(left_front, INPUT);
  pinMode(left_rear, INPUT);
  pinMode(right_rear, INPUT);
  pinMode(right_front, INPUT);
}

void enable_motors() {
  left_front_motor.attach(left_front);    // attaches the servo on pin left_front to turn Vex Motor Controller 29 On
  left_rear_motor.attach(left_rear);     // attaches the servo on pin left_rear to turn Vex Motor Controller 29 On
  right_rear_motor.attach(right_rear);   // attaches the servo on pin right_rear to turn Vex Motor Controller 29 On
  right_front_motor.attach(right_front);  // attaches the servo on pin right_front to turn Vex Motor Controller 29 On
}

