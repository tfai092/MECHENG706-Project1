int read_sonar() {
  // Clear trigger
  digitalWrite(trigPin, LOW);
  delayMicroseconds(2);

  // Send 10µs pulse
  digitalWrite(trigPin, HIGH);
  delayMicroseconds(10);
  digitalWrite(trigPin, LOW);

  // Read echo time
  duration = pulseIn(echoPin, HIGH);

  // Convert time to distance
  distance_cm = duration * 0.0343 / 2;

  return distance_cm;
}

#define kppp 1
void forward(float a, float b, float c, float d) {
  left_front_motor.writeMicroseconds(1500 + kppp*a);
  left_rear_motor.writeMicroseconds(1500 + kppp*d);
  right_rear_motor.writeMicroseconds(1500 + kppp*c);
  right_front_motor.writeMicroseconds(1500 + kppp*b);
}

void reverse(float a, float b, float c, float d) {
  left_front_motor.writeMicroseconds(1500 - kppp*a);
  left_rear_motor.writeMicroseconds(1500 - kppp*d);
  right_rear_motor.writeMicroseconds(1500 - kppp*c);
  right_front_motor.writeMicroseconds(1500 - kppp*b);
}

void ccw(float speed_ccw) {
  left_front_motor.writeMicroseconds(1500 - speed_ccw);
  left_rear_motor.writeMicroseconds(1500 - speed_ccw);
  right_rear_motor.writeMicroseconds(1500 - speed_ccw);
  right_front_motor.writeMicroseconds(1500 - speed_ccw);
}

void cw(float speed_cw) {
  left_front_motor.writeMicroseconds(1500 + speed_cw);
  left_rear_motor.writeMicroseconds(1500 + speed_cw);
  right_rear_motor.writeMicroseconds(1500 + speed_cw);
  right_front_motor.writeMicroseconds(1500 + speed_cw);
}

void strafe_left(float speed_left) {
  //left_front_motor.writeMicroseconds(1500 + speed_left);
  //left_rear_motor.writeMicroseconds(1500 + speed_left);
  //right_rear_motor.writeMicroseconds(1500 - speed_left);
  right_front_motor.writeMicroseconds(1500 + speed_left);
}

void strafe_right(float a, float b, float c, float d) {
  left_front_motor.writeMicroseconds(1500 - kppp*a);   // forward
  left_rear_motor.writeMicroseconds(1500 + kppp*d);    // backward
  right_rear_motor.writeMicroseconds(1500 - kppp*c);   // forward (right side is reversed)
  right_front_motor.writeMicroseconds(1500 + kppp*b);  // backward (right side is reversed)
}
