#include <Wire.h>
#include <Adafruit_BNO08x.h>

Adafruit_BNO08x bno08x;

sh2_SensorValue_t sensorValue;

float theta = 0;

void setup() {

  Serial.begin(115200);
  Wire.begin();

  if (!bno08x.begin_I2C()) {
    Serial.println("BNO08X not detected");
    while (1);
  }

  Serial.println("BNO08X connected");

  // enable rotation vector report
  bno08x.enableReport(SH2_ROTATION_VECTOR);
}

void loop() {

  if (bno08x.getSensorEvent(&sensorValue)) {

    if (sensorValue.sensorId == SH2_ROTATION_VECTOR) {

      float w = sensorValue.un.rotationVector.real;
      float x = sensorValue.un.rotationVector.i;
      float y = sensorValue.un.rotationVector.j;
      float z = sensorValue.un.rotationVector.k;

      // convert quaternion to yaw angle
      float yaw = atan2(2*(w*z + x*y), 1 - 2*(y*y + z*z));

      theta = yaw * 180 / PI;   // convert to degrees

      Serial.print("Angle (Yaw): ");
      Serial.println(theta);
    }
  }
}
