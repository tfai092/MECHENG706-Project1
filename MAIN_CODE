#include <Servo.h>  //Need for Servo pulse output
#include <Adafruit_BNO08x.h>  //Need for Gyroscope
#include <SoftwareSerial.h>
#include <math.h>
#include <Wire.h>

//Gyroscope initialisation
Adafruit_BNO08x bno08x(-1);

sh2_SensorValue_t sensorValue;

//Default motor control pins
const byte left_front = 46;
const byte left_rear = 47;
const byte right_rear = 50;
const byte right_front = 51;

// For Ultrasonic sensor
const int trigPin = 48;
const int echoPin = 49;
float distance_cm;
long duration;

// Declare robot width (cm)
float robot_width = 25;

// For Homing
float error, effort;
float heading = 0;
float perpen = 334;  // Angle at wall


// Serial Data input pin
#define BLUETOOTH_RX 19
// Serial Data output pin
#define BLUETOOTH_TX 18

SoftwareSerial BluetoothSerial(BLUETOOTH_RX, BLUETOOTH_TX);

Servo left_front_motor;   // create servo object to control Vex Motor Controller 29
Servo left_rear_motor;   // create servo object to control Vex Motor Controller 29
Servo right_rear_motor;  // create servo object to control Vex Motor Controller 29
Servo right_front_motor;  // create servo object to control Vex Motor Controller 29
Servo turret_motor;

int speed_val = 100;
int speed_change;

//Serial Pointer
HardwareSerial *SerialCom;

int FRONT_SHORT_IR_SENSOR = A14; //sensor is attached on pinA14
int FRONT_LONG_IR_SENSOR = A13; //sensor is attached on pinA13
int REAR_SHORT_IR_SENSOR = A15; //sensor is attached on pinA15
int REAR_LONG_IR_SENSOR = A12; //sensor is attached on pinA12

byte serialRead = 0; //for control serial communication
int signalADCshort = 0; // the read out signal in 0-1023 corresponding to 0-5v
int signalADClong = 0; // the read out signal in 0-1023 corresponding to 0-5v

float distance_short;
float distance_long;

float distance_reading = 0;
int pos = 0;

enum State {
    HOMING,
    FORWARD,
    RIGHT,
    BACKWARD,
    STOP
  };

State state = HOMING;
State prevState = HOMING;

void setup(void) {

  pinMode(trigPin, OUTPUT);
  pinMode(echoPin, INPUT);
  digitalWrite(trigPin, LOW);

  turret_motor.attach(11);
  pinMode(LED_BUILTIN, OUTPUT);

  // Setup Gyro
  if (!bno08x.begin_I2C()) {
    Serial.println("BNO08x not detected");
    while (1);
  }

  // Enable rotation vector reporting AFTER successful initialization
  bno08x.enableReport(SH2_ROTATION_VECTOR);

  // Setup the Serial port and pointer, the pointer allows switching the debug info through the USB port(Serial) or Bluetooth port(Serial1) with ease.
  Serial.begin(115200);
  BluetoothSerial.begin(115200);
  enable_motors();
}

void loop() {

  // put your main code here, to run repeatedly:
  if (Serial.available()) { // Check for input from terminal
    
    serialRead = Serial.read(); // Read input

    if (serialRead == 49) { // Check for flag to execute, 49 is ascii for 1, stop serial printing
      Serial.end(); // end the serial communication to get the sensor data
    }
  }
  
  switch(state) {
    case HOMING:
      homing();
      state = FORWARD;
      prevState = HOMING;
      break;

    case FORWARD:
      move_forward();
      state = RIGHT;
      prevState = FORWARD;
      break;

    case RIGHT:
      move_right();
      if (prevState == FORWARD) {
        state = BACKWARD;
      } else {
        state = FORWARD;
      }
      prevState = RIGHT;
      break;

    case BACKWARD:
      move_backward();
      state = RIGHT;
      prevState = BACKWARD;
      break;

    case STOP:
      stop();
      disable_motors();
      prevState = STOP;
      break;
  }
}

  void homing() {
    // Orientate position
    orientate();
    // Move to top left corner
    move_backward();
    move_left();
  }

  void move_forward() {
    float speed = 0;

    signalADCshort = analogRead(FRONT_SHORT_IR_SENSOR); // the read out is a signal from 0-1023 corresponding to 0-5v
    signalADClong = analogRead(FRONT_LONG_IR_SENSOR);
  
    // For long range sensor
    distance_long = 17948*pow(signalADClong,-1.22); // calculate the distance using the datasheet graph
    // For short range sensor
    distance_short = 12.10/(signalADCshort*(5.0/1024.0)) - 0.42;

    while (distance_long >= 25) {
      signalADClong = analogRead(FRONT_LONG_IR_SENSOR);
      distance_long = 17948*pow(signalADClong,-1.22);
      forward(0.1 * signalADClong);
    }

    while (distance_short >= 15) {
      signalADCshort = analogRead(FRONT_SHORT_IR_SENSOR);
      distance_short = 12.10/(signalADCshort*(5.0/1024.0)) - 0.42;
      forward(0.1 * signalADCshort);
    }
    stop();
  } 

  void move_right() {
    float starting_distance = 0;
    // Clear trigger
    digitalWrite(trigPin, LOW);
    delayMicroseconds(2);

    // Send 10µs pulse
    digitalWrite(trigPin, HIGH);
    delayMicroseconds(10);
    digitalWrite(trigPin, LOW);

    // Read echo time
    duration = pulseIn(echoPin, HIGH);

    // Convert time to distance
    distance_cm = duration * 0.0343 / 2;
    starting_distance = distance_cm;

    while (distance_cm < (starting_distance + robot_width)) {
      strafe_right(0.1 * ((starting_distance + robot_width) - distance_cm));
      // Clear trigger
      digitalWrite(trigPin, LOW);
      delayMicroseconds(2);

      // Send 10µs pulse
      digitalWrite(trigPin, HIGH);
      delayMicroseconds(10);
      digitalWrite(trigPin, LOW);

      // Read echo time
      duration = pulseIn(echoPin, HIGH);

      // Convert time to distance
      distance_cm = duration * 0.0343 / 2;
    }
    stop();
  }

  void move_left() {
    float starting_distance = 0;
    // Clear trigger
    digitalWrite(trigPin, LOW);
    delayMicroseconds(2);

    // Send 10µs pulse
    digitalWrite(trigPin, HIGH);
    delayMicroseconds(10);
    digitalWrite(trigPin, LOW);

    // Read echo time
    duration = pulseIn(echoPin, HIGH);

    // Convert time to distance
    distance_cm = duration * 0.0343 / 2;
    starting_distance = distance_cm;

    while (distance_cm > 15) {
      strafe_left(0.1 * distance_cm);
      // Clear trigger
      digitalWrite(trigPin, LOW);
      delayMicroseconds(2);

      // Send 10µs pulse
      digitalWrite(trigPin, HIGH);
      delayMicroseconds(10);
      digitalWrite(trigPin, LOW);

      // Read echo time
      duration = pulseIn(echoPin, HIGH);

      // Convert time to distance
      distance_cm = duration * 0.0343 / 2;
    }
    stop();
  }

  void move_backward() {
    float speed = 0;

    signalADCshort = analogRead(REAR_SHORT_IR_SENSOR); // the read out is a signal from 0-1023 corresponding to 0-5v
    signalADClong = analogRead(REAR_LONG_IR_SENSOR);
  
    // For long range sensor
    distance_long = 17948*pow(signalADClong,-1.22); // calculate the distance using the datasheet graph
    // For short range sensor
    distance_short = 12.10/(signalADCshort*(5.0/1024.0)) - 0.42;

    while (distance_long >= 25) {
      signalADClong = analogRead(REAR_LONG_IR_SENSOR);
      distance_long = 17948*pow(signalADClong,-1.22);
      reverse(0.1 * signalADClong);
    }

    while (distance_short >= 15) {
      signalADCshort = analogRead(REAR_SHORT_IR_SENSOR);
      distance_short = 12.10/(signalADCshort*(5.0/1024.0)) - 0.42;
      reverse(0.1 * signalADCshort);
    }
    stop();
  }

void orientate() {
  readOrientation();
  error = perpen - heading; // Desired angle(perpendicular to wall) - current compass angle

  while (abs(error) > 2) {
    readOrientation();
    error = perpen - heading; // Desired angle(perpendicular to wall) - current compass angle
    effort = error * 0.1;  // Control effort

    if (error > 0) {
      // Serial.println("CW ");
      cw(effort);
    }
    else {
      // Serial.println("CCW ");
      ccw(effort);
    }
  }
}

void readOrientation() {

  if (bno08x.getSensorEvent(&sensorValue)) {
    if (sensorValue.sensorId == SH2_ROTATION_VECTOR) {
      float qw = sensorValue.un.rotationVector.real;
      float qx = sensorValue.un.rotationVector.i;
      float qy = sensorValue.un.rotationVector.j;
      float qz = sensorValue.un.rotationVector.k;

      float yaw = atan2(2.0*(qx*qy + qw*qz), (qw*qw + qx*qx - qy*qy - qz*qz));

      heading = yaw * 180.0 / PI;

      if (heading < 0)
        heading += 360;
    }
  }
}

void disable_motors() {
  left_front_motor.detach();   // detach the servo on pin left_front to turn Vex Motor Controller 29 Off
  left_rear_motor.detach();   // detach the servo on pin left_rear to turn Vex Motor Controller 29 Off
  right_rear_motor.detach();  // detach the servo on pin right_rear to turn Vex Motor Controller 29 Off
  right_front_motor.detach();  // detach the servo on pin right_front to turn Vex Motor Controller 29 Off

  pinMode(left_front, INPUT);
  pinMode(left_rear, INPUT);
  pinMode(right_rear, INPUT);
  pinMode(right_front, INPUT);
}

void enable_motors() {
  left_front_motor.attach(left_front);    // attaches the servo on pin left_front to turn Vex Motor Controller 29 On
  left_rear_motor.attach(left_rear);     // attaches the servo on pin left_rear to turn Vex Motor Controller 29 On
  right_rear_motor.attach(right_rear);   // attaches the servo on pin right_rear to turn Vex Motor Controller 29 On
  right_front_motor.attach(right_front);  // attaches the servo on pin right_front to turn Vex Motor Controller 29 On
}

void stop()
{
  left_front_motor.writeMicroseconds(1500);
  left_rear_motor.writeMicroseconds(1500);
  right_rear_motor.writeMicroseconds(1500);
  right_front_motor.writeMicroseconds(1500);
}

void forward(float speed_forward) {
  left_front_motor.writeMicroseconds(1500 + speed_forward);
  left_rear_motor.writeMicroseconds(1500 + speed_forward);
  right_rear_motor.writeMicroseconds(1500 - speed_forward);
  right_front_motor.writeMicroseconds(1500 - speed_forward);
}

void reverse(float speed_backward) {
  left_front_motor.writeMicroseconds(1500 - speed_backward);
  left_rear_motor.writeMicroseconds(1500 - speed_backward);
  right_rear_motor.writeMicroseconds(1500 + speed_backward);
  right_front_motor.writeMicroseconds(1500 + speed_backward);
}

void ccw(float speed_ccw) {
  left_front_motor.writeMicroseconds(1500 - speed_ccw);
  left_rear_motor.writeMicroseconds(1500 - speed_ccw);
  right_rear_motor.writeMicroseconds(1500 - speed_ccw);
  right_front_motor.writeMicroseconds(1500 - speed_ccw);
}

void cw(float speed_cw) {
  left_front_motor.writeMicroseconds(1500 + speed_cw);
  left_rear_motor.writeMicroseconds(1500 + speed_cw);
  right_rear_motor.writeMicroseconds(1500 + speed_cw);
  right_front_motor.writeMicroseconds(1500 + speed_cw);
}

void strafe_left(float speed_left) {
  left_front_motor.writeMicroseconds(1500 - speed_left);
  left_rear_motor.writeMicroseconds(1500 + speed_left);
  right_rear_motor.writeMicroseconds(1500 + speed_left);
  right_front_motor.writeMicroseconds(1500 - speed_left);
}

void strafe_right(float speed_right) {
  left_front_motor.writeMicroseconds(1500 + speed_right);
  left_rear_motor.writeMicroseconds(1500 - speed_right);
  right_rear_motor.writeMicroseconds(1500 - speed_right);
  right_front_motor.writeMicroseconds(1500 + speed_right);
}
