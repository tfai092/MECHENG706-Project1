void driveBackwardStraight(float target_heading)
{
  float Kp = 1.2;   // heading correction gain (tune this)
  float rearsignalADClong = analogRead(REAR_LONG_IR_SENSOR);

  float rear_distance_long = 17948 * pow(rearsignalADClong, -1.22);

  while (rear_distance_long > 15) {
    
    rearsignalADClong = analogRead(REAR_LONG_IR_SENSOR);
    rear_distance_long = 17948 * pow(rearsignalADClong, -1.22);

    readOrientation();
    float error = angleDiff(best_heading, heading);

    // deadband to prevent jitter
    if (abs(error) < 1.5) {
      error = 0;
    }
    // correction term
    float correction = Kp * error;
    correction = constrain(correction, -300, 300);

    int left_cmd  = 1600 - correction;
    int right_cmd = 1600 + correction;

    left_cmd  = constrain(left_cmd, 1300, 1700);
    right_cmd = constrain(right_cmd, 1300, 1700);

    // SIMPLE FORWARD DRIVE (no IK)
    DriveBackward(left_cmd, right_cmd, left_cmd, right_cmd);
  }
  stop();
}

void driveForwardStraight(float target_heading)
{
  float Kp = 1.2;   // heading correction gain (tune this)
  float frontsignalADClong = analogRead(FRONT_LONG_IR_SENSOR);

  float front_distance_long = 17948 * pow(frontsignalADClong, -1.22);

  while (front_distance_long > 15) {

    float frontsignalADClong = analogRead(FRONT_LONG_IR_SENSOR);
    float front_distance_long = 17948 * pow(frontsignalADClong, -1.22);

    readOrientation();
    float error = angleDiff(target_heading, heading);

    // deadband to prevent jitter
    if (abs(error) < 1.5) {
      error = 0;
    }
    // correction term
    float correction = Kp * error;
    correction = constrain(correction, -300, 300);

    int left_cmd  = 1600 - correction;
    int right_cmd = 1600 + correction;

    left_cmd  = constrain(left_cmd, 1300, 1700);
    right_cmd = constrain(right_cmd, 1300, 1700);

    // SIMPLE FORWARD DRIVE (no IK)
    Driveforward(left_cmd, right_cmd, left_cmd, right_cmd);
  }
  stop();
}

float get_filtered_distance() {
  float median = read_sonar_median();

  // Reject invalid readings
  if (median < 2 || median > 400) {
    return previous_valid_distance;
  }

  // Exponential smoothing
  filtered_distance = alpha * median + (1 - alpha) * filtered_distance;

  previous_valid_distance = filtered_distance;

  return filtered_distance;
}

//---------------- MEDIAN FILTER ----------------//

float read_sonar_median() {
  for (int i = 0; i < MEDIAN_SIZE; i++) {
    sonar_samples[i] = read_sonar();
    delay(5);
  }

  // Sort values
  for (int i = 0; i < MEDIAN_SIZE - 1; i++) {
    for (int j = i + 1; j < MEDIAN_SIZE; j++) {
      if (sonar_samples[j] < sonar_samples[i]) {
        float temp = sonar_samples[i];
        sonar_samples[i] = sonar_samples[j];
        sonar_samples[j] = temp;
      }
    }
  }

  return sonar_samples[MEDIAN_SIZE / 2];
}

void MapOrientation () {

  // read both long distance sensors

  float frontsignalADClong = analogRead(FRONT_LONG_IR_SENSOR);
  float rearsignalADClong  = analogRead(REAR_LONG_IR_SENSOR);

  float front_distance_long = 17948 * pow(frontsignalADClong, -1.22);
  float rear_distance_long  = 17948 * pow(rearsignalADClong, -1.22);

  if (front_distance_long + rear_distance_long + ROBOT_LENGTH < MAP_LENGTH - 20) {
    MAP_ORIENTATION = true;
  } else {
    MAP_ORIENTATION = false;
  }
}

bool mapCompleteAfterNextRightShift() {
  float cross_map_dimension = MAP_ORIENTATION ? MAP_WIDTH : MAP_LENGTH;

  // Predict where the robot centreline would be after the next lane shift
  float next_distance_from_wall = distance_from_wall + LANE_SPACING;

  // Stop when the robot would no longer fit inside the map
  if (next_distance_from_wall + (ROBOT_WIDTH / 2.0) >= cross_map_dimension - MAP_EDGE_MARGIN) {
    return true;
  }

  return false;
}


