void rotateToAngle(float target_heading) {
  target_heading = wrap360(target_heading);

  readOrientation();
  float error = angleDiff(target_heading, heading);

  while (abs(error) > 1.0) {
    readOrientation();
    error = angleDiff(target_heading, heading);

    int turnSpeed = (int)(3.5 * abs(error));
    turnSpeed = constrain(turnSpeed, 45, 140);

    // BluetoothSerial.print("Rotate target: ");
    // BluetoothSerial.print(target_heading);
    // BluetoothSerial.print("  heading: ");
    // BluetoothSerial.print(heading);
    BluetoothSerial.print("  error: ");
    BluetoothSerial.println(error);

    if (error > 0) {
      rotateCCWRaw(turnSpeed);
    } else {
      rotateCWRaw(turnSpeed);
    }

    delay(15);
  }

  stop();
  delay(120);

  // Fine correction pass in case of overshoot/coast
  readOrientation();
  error = angleDiff(target_heading, heading);

  while (abs(error) > 1) {
    readOrientation();
    error = angleDiff(target_heading, heading);

    int turnSpeed = 30;   // gentle trim speed

    BluetoothSerial.print("  error: ");
    BluetoothSerial.println(error);

    if (error > 0) {
      rotateCCWRaw(turnSpeed);
    } else {
      rotateCWRaw(turnSpeed);
    }

    delay(10);
    stop();
    delay(25);
  }

  stop();
}

float refineBestHeading(float coarse_heading) {
  const float window = 20.0;   // scan +/- 12 deg around coarse estimate
  float local_best_heading = coarse_heading;
  float local_min_distance = 9999.0;

  // Start a little before the estimated minimum
  float start_heading = wrap360(coarse_heading - window);
  rotateToAngle(start_heading);
  delay(150);

  readOrientation();
  float prev_heading = heading;
  float swept = 0.0;

  while (swept < 2.0 * window) {
    rotateCCWRaw(55);   // slower than full scan
    delay(20);

    readOrientation();

    float sonar_sum = 0.0;
    int valid_reads = 0;

    for (int i = 0; i < 5; i++) {
      float d = read_sonar();
      if (d > 0) {
        sonar_sum += d;
        valid_reads++;
      }
      delay(5);
    }

    float sonar_avg = (valid_reads > 0) ? sonar_sum / valid_reads : 9999.0;

    float step = absAngleStep(heading, prev_heading);
    swept += step;
    prev_heading = heading;

    if (sonar_avg < local_min_distance) {
      local_min_distance = sonar_avg;
      local_best_heading = heading;
    }
  }

  stop();
  delay(150);

  return local_best_heading;
}

void rotateThatBi() {
  readOrientation();
  float prev_heading = heading;
  float swept_angle = 0.0;

  float min_distance = 9999.0;
  float best_heading = heading;

  const int scanSpeed = 90;     // constant speed for whole scan
  const float min_update_margin = 0.5;   // only accept a new min if clearly lower

  while (swept_angle < 360.0) {
    rotateCCWRaw(scanSpeed);
    delay(10);

    readOrientation();

    float sonar_distance = 0.0;
    int valid_reads = 0;

    for (int i = 0; i < 3; i++) {
      float d = read_sonar();
      if (d > 0) {
        sonar_distance += d;
        valid_reads++;
      }
      delay(5);
    }

    if (valid_reads > 0) {
      sonar_distance /= valid_reads;
    } else {
      sonar_distance = 9999.0;
    }

    float step = absAngleStep(heading, prev_heading);
    swept_angle += step;
    prev_heading = heading;

    //BluetoothSerial.print("Heading: ");
    //BluetoothSerial.print(heading);
    BluetoothSerial.print("  Sonar: ");
    BluetoothSerial.println(sonar_distance);
    //BluetoothSerial.print("  Swept: ");
    //BluetoothSerial.println(swept_angle);

    // update only if genuinely lower
    if (sonar_distance < (min_distance - min_update_margin)) {
      min_distance = sonar_distance;
      best_heading = heading;

      BluetoothSerial.print("NEW MIN -> dist: ");
      BluetoothSerial.print(min_distance);
      BluetoothSerial.print(" heading: ");
      BluetoothSerial.println(best_heading);
    }
  }

  stop();
  delay(200);

  // refine the coarse minimum with a slow local scan
  best_heading = refineBestHeading(best_heading);

  rotateToAngle(best_heading);
  wall_heading = best_heading;
}

void readOrientation() {
  if (bno08x.getSensorEvent(&sensorValue)) {

    if (sensorValue.sensorId == SH2_GAME_ROTATION_VECTOR) {

      float qw = sensorValue.un.gameRotationVector.real;
      float qx = sensorValue.un.gameRotationVector.i;
      float qy = sensorValue.un.gameRotationVector.j;
      float qz = sensorValue.un.gameRotationVector.k;

      // Convert quaternion to yaw (heading)
      float yaw = atan2(2.0 * (qx*qy + qw*qz),
                        qw*qw + qx*qx - qy*qy - qz*qz);

      heading = yaw * 180.0 / PI;

      if (heading < 0)
        heading += 360;
    }
  }
}

void disable_motors() {
  left_front_motor.detach();   // detach the servo on pin left_front to turn Vex Motor Controller 29 Off
  left_rear_motor.detach();   // detach the servo on pin left_rear to turn Vex Motor Controller 29 Off
  right_rear_motor.detach();  // detach the servo on pin right_rear to turn Vex Motor Controller 29 Off
  right_front_motor.detach();  // detach the servo on pin right_front to turn Vex Motor Controller 29 Off

  pinMode(left_front, INPUT);
  pinMode(left_rear, INPUT);
  pinMode(right_rear, INPUT);
  pinMode(right_front, INPUT);
}

void enable_motors() {
  left_front_motor.attach(left_front);    // attaches the servo on pin left_front to turn Vex Motor Controller 29 On
  left_rear_motor.attach(left_rear);     // attaches the servo on pin left_rear to turn Vex Motor Controller 29 On
  right_rear_motor.attach(right_rear);   // attaches the servo on pin right_rear to turn Vex Motor Controller 29 On
  right_front_motor.attach(right_front);  // attaches the servo on pin right_front to turn Vex Motor Controller 29 On
}

void stop()
{
  left_front_motor.writeMicroseconds(1500);
  left_rear_motor.writeMicroseconds(1500);
  right_rear_motor.writeMicroseconds(1500);
  right_front_motor.writeMicroseconds(1500);
}

int read_sonar() {
  // Clear trigger
  digitalWrite(trigPin, LOW);
  delayMicroseconds(2);

  // Send 10µs pulse
  digitalWrite(trigPin, HIGH);
  delayMicroseconds(10);
  digitalWrite(trigPin, LOW);

  // Read echo time
  duration = pulseIn(echoPin, HIGH);

  // Convert time to distance
  distance_cm = duration * 0.0343 / 2;

  return distance_cm;
}

