void Driveforward(float a, float b, float c, float d) {
  left_front_motor.writeMicroseconds(1500 + a);
  left_rear_motor.writeMicroseconds(1500 + d);
  right_rear_motor.writeMicroseconds(1500 + c);
  right_front_motor.writeMicroseconds(1500 + b);
}

void DriveBackward(float a, float b, float c, float d) {
  left_front_motor.writeMicroseconds(1500 - a);
  left_rear_motor.writeMicroseconds(1500 - d);
  right_rear_motor.writeMicroseconds(1500 - c);
  right_front_motor.writeMicroseconds(1500 - b);
}

void forward(float a, float b, float c, float d) {
  left_front_motor.writeMicroseconds(1500 + kplf*a);
  left_rear_motor.writeMicroseconds(1500 + kplr*d);
  right_rear_motor.writeMicroseconds(1500 + kprr*c);
  right_front_motor.writeMicroseconds(1500 + kprf*b);
}

void reverse(float a, float b, float c, float d) {
  left_front_motor.writeMicroseconds(1500 - kplf*a);
  left_rear_motor.writeMicroseconds(1500 - kplr*d);
  right_rear_motor.writeMicroseconds(1500 - kprr*c);
  right_front_motor.writeMicroseconds(1500 - kprf*b);
}

void ccw(float a, float b, float c, float d) {
  left_front_motor.writeMicroseconds(1500 + kplf*a);
  left_rear_motor.writeMicroseconds(1500 + kplr*d);
  right_rear_motor.writeMicroseconds(1500 + kprr*c);
  right_front_motor.writeMicroseconds(1500 + kprf*b);
}

void cw(float a, float b, float c, float d) {
  left_front_motor.writeMicroseconds(1500 + kplf*a);
  left_rear_motor.writeMicroseconds(1500 + kplr*d);
  right_rear_motor.writeMicroseconds(1500 + kprr*c);
  right_front_motor.writeMicroseconds(1500 + kprf*b);
}

void strafe_left(float a, float b, float c, float d) {
  left_front_motor.writeMicroseconds(1500 + kplf*a);   // forward
  left_rear_motor.writeMicroseconds(1500 + kplr*d);    // backward
  right_rear_motor.writeMicroseconds(1500 + kprr*c);   // forward (right side is reversed)
  right_front_motor.writeMicroseconds(1500 + kprf*b);
}

void strafe_right(float a, float b, float c, float d) {
  left_front_motor.writeMicroseconds(1500 + kplf*a);   // forward
  left_rear_motor.writeMicroseconds(1500 + kplr*d);    // backward
  right_rear_motor.writeMicroseconds(1500 + kprr*c);   // forward (right side is reversed)
  right_front_motor.writeMicroseconds(1500 + kprf*b);  // backward (right side is reversed)
}
#define kp_rotation 1.4
void rotateCCWRaw(int speed_cmd) {
  // tune sign if robot turns wrong way
  left_front_motor.writeMicroseconds(1500 - kp_rotation * speed_cmd);
  left_rear_motor.writeMicroseconds(1500 - kp_rotation * speed_cmd);
  right_rear_motor.writeMicroseconds(1500 - 1.25 * kp_rotation * speed_cmd);
  right_front_motor.writeMicroseconds(1500 - 1.25 * kp_rotation * speed_cmd);
}

void rotateCWRaw(int speed_cmd) {
  // tune sign if robot turns wrong way
  left_front_motor.writeMicroseconds(1500 + kp_rotation * speed_cmd);
  left_rear_motor.writeMicroseconds(1500 + kp_rotation * speed_cmd);
  right_rear_motor.writeMicroseconds(1500 + 1.25 * kp_rotation * speed_cmd);
  right_front_motor.writeMicroseconds(1500 + 1.25 * kp_rotation * speed_cmd);
}
