    distance_from_wall += LANE_SPACING;
  }

  if (prevState == FORWARD) {
    state = BACKWARD;
  } else {
    state = FORWARD;
  }

  prevState = RIGHT;
  break;

    case BACKWARD:
    BluetoothSerial.println("NEXT STATE = BACKWARD");

      if (prevState == HOMING) {
        state = LEFT;
      } else  {
        state = RIGHT;
      }
