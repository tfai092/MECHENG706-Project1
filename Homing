// -------- SETUP --------
void setup() {

  Serial.begin(115200);
  BluetoothSerial.begin(115200);

  if (!bno08x.begin_I2C()) {
    Serial.println("BNO08X not detected");
    while (1);
  }
  // Enable rotation vector (gives orientation)
  if (!bno08x.enableReport(SH2_ROTATION_VECTOR)) {
    Serial.println("Could not enable rotation vector");
  }

  Serial.println("BNO08X Found!");

  left_font_motor.attach(left_front);
  left_rear_motor.attach(left_rear);
  right_rear_motor.attach(right_rear);
  right_font_motor.attach(right_front);

}

void loop() {

  // Orientate position
  orientate();
  // Move to top left corner
  moveToCorner();

}

void orientate() {
    readOrientation();
    error = perpen - heading; // Desired angle(perpendicular to wall) - current compass angle
    effort = error * kp;  // Control effort

    if (error > 0) {
    Serial.print("CW ");
        cw();
    }
    else {
    Serial.print("CCW ");

        ccw();
    }

    if (abs(error) < 0.2) {
        stop();
    }
  
}

float readOrientation() {
  if (bno08x.getSensorEvent(&sensorValue)) {

    if (sensorValue.sensorId == SH2_ROTATION_VECTOR) {

      float qw = sensorValue.un.rotationVector.real;
      float qx = sensorValue.un.rotationVector.i;
      float qy = sensorValue.un.rotationVector.j;
      float qz = sensorValue.un.rotationVector.k;

      // Convert quaternion to yaw (heading)
      float yaw = atan2(2.0*(qx*qy + qw*qz),
                        qw*qw + qx*qx - qy*qy - qz*qz);

      float heading = yaw * 180.0 / PI;

      if (heading < 0)
        heading += 360;
    }
  }
  return heading;
}

float readSensors() {

  front_short = analogRead(FRONT_SHORT_IR_SENSOR);
  front_long  = analogRead(FRONT_LONG_IR_SENSOR);
  rear_short  = analogRead(REAR_SHORT_IR_SENSOR);
  rear_long   = analogRead(REAR_LONG_IR_SENSOR);

  calculateDistances(front_short, front_long, rear_short, rear_long);

  return front_short, front_long, rear_short, rear_long;
}

float calculateDistances(float front_short, float front_long, float rear_short, float rear_long) {

  distance_fs = 46161 * pow(front_short, -1.302);
  distance_fl = 46161 * pow(front_long,  -1.302);
  distance_rs = 46161 * pow(rear_short, -1.302);
  distance_rl = 46161 * pow(rear_long,  -1.302);

  return front_short, front_long, rear_short, rear_long;
}

