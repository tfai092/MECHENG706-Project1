void ccw() {
  left_font_motor.writeMicroseconds((1500 - speed_val) * effort);
  left_rear_motor.writeMicroseconds((1500 - speed_val) * effort);
  right_rear_motor.writeMicroseconds((1500 - speed_val) * effort);
  right_font_motor.writeMicroseconds((1500 - speed_val) * effort);
}

void cw() {
  left_font_motor.writeMicroseconds((1500 + speed_val) * effort);
  left_rear_motor.writeMicroseconds((1500 + speed_val) * effort);
  right_rear_motor.writeMicroseconds((1500 + speed_val) * effort);
  right_font_motor.writeMicroseconds((1500 + speed_val) * effort);
}

void strafe_left() {

  left_font_motor.writeMicroseconds(1500 - speed_val);
  left_rear_motor.writeMicroseconds(1500 + speed_val);

  right_rear_motor.writeMicroseconds(1500 + speed_val);
  right_font_motor.writeMicroseconds(1500 - speed_val);

}

void strafe_right() {

  left_font_motor.writeMicroseconds(1500 + speed_val);
  left_rear_motor.writeMicroseconds(1500 - speed_val);

  right_rear_motor.writeMicroseconds(1500 - speed_val);
  right_font_motor.writeMicroseconds(1500 + speed_val);

}
