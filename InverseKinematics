void setup(void) {

  pinMode(trigPin, OUTPUT);
  pinMode(echoPin, INPUT);
  digitalWrite(trigPin, LOW);

  turret_motor.attach(11);
  pinMode(LED_BUILTIN, OUTPUT);

  // Setup Gyro
  if (!bno08x.begin_I2C()) {
    Serial.println("BNO08x not detected");
    while (1);
  }

  // Enable rotation vector reporting AFTER successful initialization
  bno08x.enableReport(SH2_ROTATION_VECTOR);

  // Setup the Serial port and pointer, the pointer allows switching the debug info through the USB port(Serial) or Bluetooth port(Serial1) with ease.
  Serial.begin(115200);
  BluetoothSerial.begin(115200);
  enable_motors();
}

void loop() {

  // put your main code here, to run repeatedly:
  if (Serial.available()) { // Check for input from terminal
    
    serialRead = Serial.read(); // Read input

    if (serialRead == 49) { // Check for flag to execute, 49 is ascii for 1, stop serial printing
      Serial.end(); // end the serial communication to get the sensor data
    }
  }
  
  switch(state) {
    case HOMING:
      homing();
      state = FORWARD;
      prevState = HOMING;
      break;

    case FORWARD:
      DriveStraight(); // TESTING CHANGE THISSSSSSSSSSSSSSSSSSSSSSSSSSSSSSSSSSSSSSS
      //state = RIGHT;
      //prevState = FORWARD;
      break;

    case RIGHT:
      move_right();
      if (prevState == FORWARD) {
        state = BACKWARD;
      } else {
        state = FORWARD;
      }
      prevState = RIGHT;
      break;

    case BACKWARD:
      move_backward();
      state = RIGHT;
      prevState = BACKWARD;
      break;

    case STOP:
      stop();
      disable_motors();
      prevState = STOP;
      break;
  }
}

